# .claudeignore
node_modules/
dist/
build/
.swc/
coverage/

# Bỏ qua các file lock khổng lồ (Rất quan trọng để tiết kiệm token)
package-lock.json
bun.lock
bun.lockb
yarn.lock

# Bỏ qua các file Media/Assets (Claude không cần đọc mã nhị phân của ảnh)
public/images/
brand_assets/
**/*.svg
**/*.png
**/*.webp
**/*.ico

# Bỏ qua các thư mục cấu hình Supabase tĩnh không cần AI sửa
supabase/migrations/

# Playwright outputs
playwright-report/
test-results/
blob-report/
playwright/.cache/

# Ignore luôn các thư mục chứa ảnh/video test
**/*.webm
**/*.png
**/*.zip